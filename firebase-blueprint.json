{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and preferences",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "preferredGenres": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email"]
    },
    "Interaction": {
      "title": "Interaction",
      "description": "User interaction with a movie or search",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["search", "click", "favorite"] },
        "movieTitle": { "type": "string" },
        "genres": { "type": "array", "items": { "type": "string" } },
        "query": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "The user's profile document"
    },
    "/users/{userId}/interactions/{interactionId}": {
      "schema": "Interaction",
      "description": "History of user interactions"
    }
  }
}
